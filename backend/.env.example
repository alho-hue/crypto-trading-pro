# NEUROVEST Backend Environment Variables

# Database
MONGODB_URI=mongodb://localhost:27017/neurovest

# JWT (REQUIRED - Must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Encryption (REQUIRED - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here-32-bytes-in-hex

# RSA Keys (REQUIRED for API key encryption - Generate with securityService)
RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Binance API (Optional - can be set per user)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=false

# Groq AI API Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# Admin Configuration - NEW SECURE SYSTEM
# ⚠️  SUPPRIMER l'ancien système ADMIN_CODES - REMPLACÉ par celui-ci

# Admin 1 (Super Admin / Fondateur)
ADMIN_EMAIL_1=admin1@neurovest.com
ADMIN_PASSWORD_1=SuperSecurePassword123!
ADMIN_ROLE_1=super_admin

# Admin 2
ADMIN_EMAIL_2=admin2@neurovest.com
ADMIN_PASSWORD_2=SuperSecurePassword456!
ADMIN_ROLE_2=admin

# Admin 3
ADMIN_EMAIL_3=admin3@neurovest.com
ADMIN_PASSWORD_3=SuperSecurePassword789!
ADMIN_ROLE_3=moderator

# Admin Token Settings
ADMIN_TOKEN_EXPIRY=8h

# Admin Rate Limiting (plus strict que user normal)
ADMIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_RATE_LIMIT_MAX_REQUESTS=300
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=30

# File Upload
MAX_FILE_SIZE=5242880

# Security
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Telegram (Optional - for bot notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
